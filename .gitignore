# --- Custom Ignored Patterns ---
# Ignore environment variables (High Priority)
.env
.env.local
.env.*

# Ignore all contents inside any 'docs' folder
docs/**/*

# --- Standard Python Ignores ---
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
bin/
build/
develop-eggs/
dist/
eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual Environments
.venv/
venv/
ENV/
env/
python/

# IDE specific (Optional but recommended)
.vscode/
.idea/